{
    "name": "nicxonsolutions/html",
    "description": "HTML and Form Builders for the Laravel Framework",
    "version": "1.0.0",
    "license": "MIT",
    "homepage": "https://github.com/robertnicjoo/html",
    "support": {
        "issues": "https://github.com/robertnicjoo/html/issues",
        "source": "https://github.com/robertnicjoo/html"
    },
    "authors": [
        {
            "name": "Nicxon Solutions",
            "email": "dev@nicxonsolutions.com",
            "homepage": "https://nicxonsolutions.com"
        },
        {
            "name": "Robert Nicjoo",
            "homepage": "https://github.com/robertnicjoo"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/session": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "illuminate/database": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "mockery/mockery": "~1.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Nicxonsolutions\\Html\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "Nicxonsolutions\\Html\\HtmlServiceProvider"
            ],
            "aliases": {
                "Form": "Nicxonsolutions\\Html\\FormFacade",
                "Html": "Nicxonsolutions\\Html\\HtmlFacade"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

